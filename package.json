{
  "name": "normalizer.app",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "src/index.tsx",
  "module": "src/index.tsx",
  "scripts": {
    "app": "bun docker:app",
    "server": "bun run --hot src/index.tsx",
    "docker:up": "COMPOSE_BAKE=true docker-compose up --build",
    "docker:down": "docker-compose down",
    "docker:restart": "docker-compose restart",
    "docker:logs": "docker-compose logs -f app",
    "docker:shell": "docker-compose exec app bun shell",
    "docker:clean": "docker-compose down -v --remove-orphans",
    "docker:app": "bun docker:down && COMPOSE_BAKE=true bun docker:up",
    "docker:dev": "COMPOSE_BAKE=true docker-compose up --build",
    "docker:prune": "docker system prune -a",
    "type-check": "tsc --noEmit --watch",
    "tc": "bun type-check"
  },
  "dependencies": {
    "bun-plugin-tailwind": "^0.0.14",
    "react": "^19",
    "react-dom": "^19",
    "tailwindcss": "^4.0.6",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@types/bun": "latest"
  }
}
