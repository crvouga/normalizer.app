{
  "name": "normalizer.app",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "src/server.tsx",
  "module": "src/server.tsx",
  "scripts": {
    "check:graphile-worker": "bun run src/lib/check-graphile-worker.ts",
    "circular": "madge --circular --extensions ts,tsx src",
    "cloc": "bun x cloc src",
    "db": "bun run db:studio",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "bun run src/db/run-migrations.ts",
    "db:push": "drizzle-kit push",
    "db:studio": "drizzle-kit studio",
    "db:up": "bun run db:migrate",
    "docker": "bun docker:down && bun docker:up",
    "docker:destroy": "docker-compose down -v --remove-orphans",
    "docker:dev": "COMPOSE_BAKE=true docker-compose up --build",
    "docker:down": "docker-compose down --remove-orphans",
    "docker:logs": "docker-compose logs -f server",
    "docker:prune": "docker system prune -a",
    "docker:restart": "docker-compose restart",
    "docker:stop": "docker stop $(docker ps -q)",
    "docker:up": "COMPOSE_BAKE=true docker-compose up --build -d",
    "e2e": "playwright test",
    "e2e:debug": "playwright test --debug",
    "e2e:ui": "playwright test --ui",
    "format": "bun x sort-package-json && bun x prettier --write .",
    "format:check": "bun x prettier --check .",
    "kp": "bun x kill-port 8080",
    "s3:up": "bun run src/db/s3-migrations.ts",
    "server": "bun run --watch src/server.tsx",
    "tc": "bun type-check",
    "test": "bun test",
    "type-check": "tsc --noEmit --watch",
    "type-check:once": "tsc --noEmit",
    "worker": "bun run --watch src/worker.tsx"
  },
  "dependencies": {
    "@headlessui/react": "^2.2.9",
    "@trpc/client": "^11.0.0",
    "@trpc/server": "^11.0.0",
    "arctic": "^3.7.0",
    "bun-plugin-tailwind": "^0.0.14",
    "drizzle-orm": "^0.44.7",
    "graphile-worker": "^0.16.6",
    "lru-cache": "^11.2.2",
    "minio": "^8.0.6",
    "openai": "^6.9.0",
    "postgres": "^3.4.7",
    "react": "^19",
    "react-dom": "^19",
    "tailwindcss": "^4.0.6",
    "xlsx": "^0.18.5",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@playwright/test": "^1.56.1",
    "@types/bun": "latest",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "drizzle-kit": "^0.30.0",
    "madge": "^8.0.0",
    "playwright": "^1.56.1",
    "prettier": "^3.6.2",
    "prettier-plugin-tailwindcss": "^0.7.1",
    "sort-package-json": "^3.4.0"
  }
}
